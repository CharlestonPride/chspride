{
  "appId": "org.charlestonpride.app",
  "appName": "Charleston Pride",
  "webDir": "../web/build",
  "server": {
    "url": "https://charlestonpride.org",
    "cleartext": false,
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#FFFFFF",
